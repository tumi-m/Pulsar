# ─────────────────────────────────────────────────────────────
# PULSAR — Environment Variables
# Copy this file to .env.local and fill in the values
# ─────────────────────────────────────────────────────────────

# ── Anthropic (REQUIRED) ─────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase (REQUIRED) ──────────────────────────────────────
# Get from: https://app.supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Search API (STRONGLY RECOMMENDED) ────────────────────────
# Option A: Brave Search — https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=BSA...

# Option B: SerpAPI — https://serpapi.com/ (fallback)
# SERP_API_KEY=...

# ── Agent security ────────────────────────────────────────────
# Any random secret to protect the /api/agent POST endpoint
# Generate: openssl rand -hex 32
AGENT_TRIGGER_SECRET=your-secret-here

# ── Scheduler (OPTIONAL) ─────────────────────────────────────
# Cron expression for daily run (default: 08:00 UTC daily)
AGENT_CRON=0 8 * * *
AGENT_TIMEZONE=UTC

# Run agent immediately when scheduler starts (for testing)
RUN_ON_START=false
