# ─────────────────────────────────────────────────────────────
# PULSAR — Environment Variables
# Copy this file to .env.local and fill in the values
# ─────────────────────────────────────────────────────────────
#
# NOTHING here is required just to see the site — the home page shows
# fresh music from the free Apple feed with zero config. These enable
# the optional persistence + curation layers.

# ── DSP playlist creation (the "Create playlist" feature) ─────
# Each configured service builds a REAL playlist on the user's account when
# they export a crate. Any service left unconfigured falls back to CSV + copy.
# All redirect URIs must exactly match your site origin + "/"
#   e.g. https://pulsar-ten-sigma.vercel.app/  (and http://127.0.0.1:3000/ local)
#
# Spotify — Authorization Code + PKCE, no secret. Create an app at
#   https://developer.spotify.com/dashboard, add the redirect URI, copy the id.
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
#
# YouTube Music — Google OAuth (implicit) + YouTube Data API v3. Create an
#   OAuth "Web application" client at https://console.cloud.google.com, enable
#   the YouTube Data API, add the redirect URI + JS origin. The `youtube` scope
#   is sensitive → the consent screen needs Google verification for public use.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
#
# Apple Music — MusicKit JS. Requires a PAID Apple Developer membership.
#   Create a MusicKit key at https://developer.apple.com/account (Keys), then:
NEXT_PUBLIC_APPLE_MUSIC_ENABLED=false
APPLE_TEAM_ID=            # 10-char Team ID
APPLE_KEY_ID=            # the MusicKit key's Key ID
APPLE_PRIVATE_KEY=       # the .p8 contents (PEM; literal \n newlines are fine)
#
# Tidal & SoundCloud have no openly-available playlist-write API (SoundCloud's
# API is closed to new apps; Tidal's write access is gated), so they always use
# the CSV + copy import flow.

# ── Supabase (for the growing archive) ───────────────────────
# Get from: https://app.supabase.com → Project Settings → API
# Needed by `npm run ingest` and the daily GitHub Action.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Open-model curation via Ollama (optional) ────────────────
# The ingest job asks this model for a curator note + mood per release.
# Local Ollama (default):
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
# Ollama Cloud / Turbo instead of local:
#   OLLAMA_BASE_URL=https://ollama.com
#   OLLAMA_API_KEY=your-ollama-key
# Tuning:
# ENRICH_LIMIT=30          # how many newest releases to enrich per run
# ENRICH_CONCURRENCY=3     # parallel requests to Ollama

# ── Agent trigger (protects the /api/agent POST endpoint) ────
# Generate: openssl rand -hex 32
AGENT_TRIGGER_SECRET=your-secret-here

# ── Optional: Claude-powered discovery agent (npm run agent) ──
# Only if you want the web-browsing curator instead of the Apple feed.
# ANTHROPIC_API_KEY=sk-ant-...
# BRAVE_SEARCH_API_KEY=BSA...

# ── Local scheduler (optional) ───────────────────────────────
AGENT_CRON=0 8 * * *
AGENT_TIMEZONE=UTC
RUN_ON_START=false
